{
  "name": "4gaboard-agent-plus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "4gaBoards 测试场景生成器 + 智能测试 Agent（TypeScript 版）",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "extract": "tsx src/extractFeatures.ts",
    "scenarios": "tsx src/generateScenarios.ts",
    "run-scenario": "tsx src/agent/cli/run.ts",
    "run-batch": "tsx src/agent/cli/run-batch.ts",
    "run-mutation": "tsx src/agent/cli/run-mutation.ts",
    "run-judge-cost": "tsx src/agent/cli/run-judge-cost.ts",
    "dev:server": "tsx watch server/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "dotenv": "^17.4.2",
    "hono": "^4.12.26",
    "openai": "^6.42.0",
    "playwright": "^1.60.0",
    "undici": "^8.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
