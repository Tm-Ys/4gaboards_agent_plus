# 4gaboards Agent Plus 环境变量模板
# 用法：cp .env.example .env，再填入真实值。.env 切勿提交到版本库。

# ===== DeepSeek（任务一/二 LLM 调用，OpenAI 兼容接口）=====
DEEPSEEK_API="sk-your-deepseek-api-key"
DEEPSEEK_URL_OPENAI="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"

# ===== 目标应用 =====
TARGET_APP_DOCS_URL="https://docs.4gaboards.com/"
TARGET_APP_DEMO_URL="https://demo.4gaboards.com/"

# ===== Embedding / Reranking（仅 RAG 对比实验用，本方案默认不走 RAG）=====
TOOL_API="sk-your-tool-api-key"
TOOL_EMBEDDING_MODEL="Qwen/Qwen3-VL-Embedding-8B"
TOOL_RERANKING_MODEL="Qwen/Qwen3-VL-Reranker-8B"
TOOL_API_URL_OPENAI="https://api.siliconflow.cn"

# ===== 4gaBoards 被测账号（任务二 Agent 登录用）=====
4GABOARD_ACCOUNT="your-account@example.com"
4GABOARD_PASSWORD="your-password"
4GABOARD_CLIENT_ID="your-client-id"
4GABOARD_PWD="your-pwd"

# ===== 检索策略（可选）: "embedding" (RAG) / "page_index" (关键词匹配) =====
# 本项目默认长上下文直填，不走检索；该变量仅用于对比实验。
# RETRIEVER_MODE=page_index
